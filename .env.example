# ── Core ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/png-gwp
PAYLOAD_SECRET=change-me-in-production

# ── App URL ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://cms.digital.gov.pg
NEXT_PUBLIC_PAYLOAD_URL=https://cms.digital.gov.pg

# ── Email (SMTP) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@gov.pg
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@gov.pg
SMTP_FROM_NAME=GoPNG Website Platform

# ── GitHub site provisioning ──────────────────────────────────────────
# PAT with scopes: repo + workflow + actions:write
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_ORG=TMJ-24
GITHUB_TEMPLATE_REPO=site-template

# ── Static site deploys ─────────────────────────────────────────────────
# S3_STATIC_SITES_BUCKET is set as a repo variable on each provisioned site-{slug}
# repo (via provisionSiteRepo.ts); DEPLOY_WEBHOOK_SECRET authenticates the callback
# each site's own GitHub Action posts to /api/deploy-webhook after it builds.
S3_STATIC_SITES_BUCKET=gopng-static-sites
AWS_REGION=ap-southeast-2
DEPLOY_WEBHOOK_SECRET=use-a-long-random-string-here

# ── Analytics (all optional — leave blank to disable) ─────────────────
# Microsoft Clarity  →  https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_ID=

# Google Analytics 4  →  https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# LinkedIn Insight Tag  →  https://www.linkedin.com/campaignmanager
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Snowplow Analytics  →  your self-hosted collector URL
NEXT_PUBLIC_SNOWPLOW_COLLECTOR=
